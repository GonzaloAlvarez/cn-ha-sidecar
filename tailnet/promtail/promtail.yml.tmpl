server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://${INFRA_VPS_TAILNET_IP}:3100/loki/api/v1/push

scrape_configs:
  - job_name: homeassistant
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: [__meta_docker_container_name]
        regex: /(homeassistant|hassio_.*)
        action: keep
      - source_labels: [__meta_docker_container_name]
        regex: /(.*)
        target_label: container
      - replacement: ha
        target_label: host
