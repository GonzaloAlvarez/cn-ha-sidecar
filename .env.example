ROOT_DOMAIN=
# Tailnet IP of the VPS (run: docker exec cloudnet-headscale-1 headscale nodes list)
INFRA_VPS_TAILNET_IP=
LAB_DOMAIN=
TAILNET_DOMAIN=
HEADSCALE_DOMAIN=

# Pre-auth key from Headscale (create with --tags tag:svc)
HA_AUTHKEY=

# LAN hostname for HA (must match what your router resolves to this host)
LAN_DOMAIN=homeassistant.lan

# Cert Warden API key (from cn-pki UI at http://127.0.0.1:8056)
CERTWARDEN_API_KEY=

# SMTP — used by Watchtower (update notifications)
SMTP_HOST=
SMTP_FROM=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL=
